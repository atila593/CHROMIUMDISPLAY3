#!/usr/bin/with-contenv bashio
set -e

bashio::log.info "Vérification de la compatibilité matérielle..."

# Vérification du GPU
if [ ! -d /dev/dri ]; then
    bashio::log.error "Aucune carte graphique détectée dans /dev/dri. Vérifiez les privilèges de l'add-on."
else
    bashio::log.info "Carte graphique trouvée avec succès."
fi

# Vérification du Tactile
if [ ! -d /dev/input ]; then
    bashio::log.warning "Aucun périphérique d'entrée trouvé dans /dev/input. Le tactile pourrait ne pas fonctionner."
else
    bashio::log.info "Périphériques d'entrée (tactile/souris) détectés."
fi

# Initialisation propre des permissions pour seatd
mkdir -p /run/user/0
chmod 700 /run/user/0
