#!/bin/bash
exec 2>&1

echo "🚀 Alignement des paramètres graphiques et de navigation..."

# 1. Environnement de base requis pour Wayland / Cage
export XDG_RUNTIME_DIR=/run/user/0
export CHROME_LOG_FILE=/dev/stdout
export EGL_PLATFORM=wayland

# 2. Configuration stricte pour libseat avec le démon dédié
export LIBSEAT_BACKEND=seatd
export WLR_LIBSEAT_BACKEND=seatd
export SEATD_SOCK=/run/seatd.sock

# Nettoyage d'une socket résiduelle éventuelle
if [ -S /run/seatd.sock ]; then
    echo "⚠️ Socket seatd résiduel détecté, nettoyage..."
    rm -f /run/seatd.sock
fi

echo "🔐 Démarrage de seatd en mode non-VT pour libérer le tactile..."
# IMPORTANT : Le drapeau "-n" empêche seatd de s'approprier les terminaux virtuels de l'hôte,
# ce qui évite les erreurs de permission et permet à Cage d'intercepter /dev/input/*
seatd -g root -n &
SEATD_PID=$!

trap 'echo "🧹 Arrêt de seatd (PID $SEATD_PID)"; kill $SEATD_PID 2>/dev/null' EXIT

# Attente de la création de la socket seatd
SEATD_READY=0
for i in $(seq 1 50); do
    if [ -S /run/seatd.sock ]; then
        SEATD_READY=1
        break
    fi
    sleep 0.1
done

if [ "$SEATD_READY" -eq 1 ]; then
    echo "✅ Le gestionnaire de sièges seatd est prêt."
else
    echo "❌ Échec de l'initialisation de seatd."
fi

chmod 0666 /run/seatd.sock 2>/dev/null

# 3. Application des permissions absolues sur les entrées tactiles et le GPU
echo "🎮 Libération des accès matériels (GPU + Dalle Tactile)..."
if [ -d /dev/input ]; then
    chmod -R 777 /dev/input/ 2>/dev/null
    echo "  -> [OK] Permissions appliquées sur /dev/input"
fi

if [ -d /dev/dri ]; then
    chmod -R 777 /dev/dri/ 2>/dev/null
    echo "  -> [OK] Permissions appliquées sur /dev/dri"
fi

# 4. Configuration du profil persistant de Chromium (pour conserver la session)
mkdir -p /data/chromium-profile
chmod -R 777 /data/chromium-profile

# 5. Récupération de l'URL cible
if [ -f /data/options.json ]; then
    URL=$(jq --raw-output '.url' /data/options.json 2>/dev/null)
fi
if [ -z "$URL" ] || [ "$URL" == "null" ]; then
    URL="http://192.168.1.XX:8123/lovelace/0?auth_callback=1"
fi

echo "Lancement de CHROMIUMDISPLAY3 via Cage..."
echo "Destination : $URL"

# 6. Exécution de Cage + Chromium
exec cage -d -- chromium-browser \
    --kiosk \
    --no-sandbox \
    --no-first-run \
    --enable-logging=stderr \
    --log-level=0 \
    --no-errdialogs \
    --disable-infobars \
    --autoplay-policy=no-user-gesture-required \
    --ozone-platform=wayland \
    --enable-gpu-rasterization \
    --enable-zero-copy \
    --touch-events=enabled \
    --enable-hardware-overlays \
    --user-data-dir=/data/chromium-profile \
    "$URL"
