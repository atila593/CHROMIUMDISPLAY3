#!/usr/bin/with-contenv bashio
set -e

bashio::log.info "Préparation de l'environnement graphique Kiosk..."

# 1. Variables d'environnement indispensables pour libseat et Chromium Ozone
export SEATD_VTBOUND=0
export LIBSEAT_BACKEND=builtin
export XDG_RUNTIME_DIR=/run/user/0
mkdir -p "$XDG_RUNTIME_DIR"
chmod 0700 "$XDG_RUNTIME_DIR"

# 2. Sécurité : On attend que le socket de seatd soit bien disponible (évite le crash au boot)
# Cela règle la boucle infinie et les 30% de CPU
if [ -f /run/seatd.sock ]; then
    export LIBSEAT_CHOWN=1
fi

# 3. Récupération de l'URL depuis la configuration de l'add-on
URL=$(bashio::config 'url')
bashio::log.info "Lancement du kiosque sur l'URL : $URL"

# 4. Lancement de Cage + Chromium avec Ozone DRM
# L'option -s de cage permet de contourner les restrictions d'exécution
exec cage -s -- chromium-browser \
    --ozone-platform=drm \
    --kiosk \
    --no-sandbox \
    --autoplay-policy=no-user-gesture-required \
    --display=:0 \
    "$URL"
