#!/bin/bash
exec 2>&1

echo "🚀 Alignement des paramètres graphiques et de navigation..."

# Environnement requis pour Wayland / Cage
export XDG_RUNTIME_DIR=/run/user/0
export CHROME_LOG_FILE=/dev/stdout
export EGL_PLATFORM=wayland

# Forcer libseat à utiliser seatd de manière transparente
export LIBSEAT_BACKEND=seatd
export WLR_LIBSEAT_BACKEND=seatd

# --- Droits et Nettoyage Matériel ---
if [ -S /run/seatd.sock ]; then
    echo "⚠️  Socket seatd résiduel détecté, nettoyage..."
    rm -f /run/seatd.sock
fi

echo "🔐 Démarrage du gestionnaire de sièges (seatd)..."
# On force l'exécution en arrière-plan
seatd -g root &
SEATD_PID=$!

trap 'echo "🧹 Arrêt de seatd (PID $SEATD_PID)"; kill $SEATD_PID 2>/dev/null' EXIT

# Attente du socket
SEATD_READY=0
for i in $(seq 1 50); do
    if [ -S /run/seatd.sock ]; then
        SEATD_READY=1
        break
    fi
    sleep 0.1
done

chmod 0666 /run/seatd.sock 2>/dev/null

# Force l'accès aux entrées tactiles pour Cage
if [ -d /dev/input ]; then
    chmod 666 /dev/input/* 2>/dev/null
fi
if [ -d /dev/dri ]; then
    chmod 666 /dev/dri/* 2>/dev/null
fi

# Configuration d'un stockage persistant pour isoler les cookies de session HA
mkdir -p /data/chromium-profile
chmod 777 /data/chromium-profile

# Récupération de l'URL cible
if [ -f /data/options.json ]; then
    URL=$(jq --raw-output '.url' /data/options.json 2>/dev/null)
fi
if [ -z "$URL" ] || [ "$URL" == "null" ]; then
    URL="http://192.168.1.XX:8123/lovelace/0?auth_callback=1"
fi

echo "Lancement de CHROMIUMDISPLAY3 via Cage..."
echo "Destination : $URL"

# Lancement de Cage + Chromium avec profil persistant et gestion tactile evdev forcee
exec cage -d -- chromium-browser \
    --kiosk \
    --no-sandbox \
    --no-first-run \
    --enable-logging=stderr \
    --log-level=0 \
    --no-errdialogs \
    --disable-infobars \
    --autoplay-policy=no-user-gesture-required \
    --ozone-platform=wayland \
    --enable-gpu-rasterization \
    --enable-zero-copy \
    --touch-events=enabled \
    --enable-hardware-overlays \
    --user-data-dir=/data/chromium-profile \
    "$URL"
