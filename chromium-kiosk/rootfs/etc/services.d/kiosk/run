#!/usr/bin/with-contenv bashio
set -e

bashio::log.info "Préparation de l'environnement graphique Kiosk..."

# 1. Configuration des chemins et variables d'environnement
export XDG_RUNTIME_DIR=/run/user/0
mkdir -p "$XDG_RUNTIME_DIR"
chmod 0700 "$XDG_RUNTIME_DIR"

# 2. Attente active de la création du socket par le service seatd
timeout=0
while [ ! -S /run/seatd.sock ]; do
    if [ "$timeout" -ge 10 ]; then
        bashio::log.error "Le socket seatd n'a pas été trouvé après 10 secondes."
        exit 1
    fi
    sleep 0.5
    timeout=$((timeout + 1))
done

# 3. Forcer la connexion vers le daemon seatd
export LIBSEAT_BACKEND=seatd
export SEATD_SOCK=/run/seatd.sock
export WLR_LIBINPUT_NO_DEVICES=1

# 4. Lancement de l'affichage
URL=$(bashio::config 'url')
bashio::log.info "Lancement du kiosque sur l'URL : $URL"

exec cage -s -- chromium-browser \
    --ozone-platform=wayland \
    --ozone-platform-hint=wayland \
    --touch-events=enabled \
    --kiosk \
    --no-sandbox \
    --autoplay-policy=no-user-gesture-required \
    --disable-features=WebRtcAllowInputVolumeAdjustment \
    "$URL"
